# ============================================================
# Copier ce fichier vers .env et personnaliser au besoin.
# Le .env n'est PAS versionné (voir .gitignore).
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=cfitv
POSTGRES_PASSWORD=cfitv_dev
POSTGRES_DB=cfitv
POSTGRES_PORT=5432

# URL de connexion utilisée par Prisma / le backend
DATABASE_URL="postgresql://cfitv:cfitv_dev@localhost:5432/cfitv?schema=public"

# ----- MinIO -----
MINIO_ROOT_USER=cfitv_admin
MINIO_ROOT_PASSWORD=cfitv_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# URL interne utilisée par le backend pour uploader (http://localhost:9000 en dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=cfitv_admin
S3_SECRET_KEY=cfitv_dev_password
S3_BUCKET_VIDEOS=videos
S3_BUCKET_THUMBNAILS=thumbnails

# ----- Redis -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- Adminer -----
ADMINER_PORT=8080

# ----- Backend -----
NODE_ENV=development
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
LOG_LEVEL=info

# Secret JWT du backend (production: valeur unique de 32+ caractères)
JWT_SECRET=cfitv_dev_jwt_secret_change_in_production_32c
# Durée de session coach/admin (exemples: 8h, 12h, 1d)
JWT_EXPIRES_IN=8h
