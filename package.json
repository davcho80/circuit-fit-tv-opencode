{
  "name": "circuit-fit-tv",
  "version": "0.1.0",
  "private": true,
  "description": "Système d'entraînement en circuit multi-écrans synchronisés",
  "workspaces": [
    "packages/*",
    "backend",
    "pwa"
  ],
  "scripts": {
    "dev": "concurrently --names \"backend,pwa\" --prefix-colors \"cyan,magenta\" \"npm run dev --workspace=@cfitv/backend\" \"npm run dev --workspace=@cfitv/pwa\"",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:reset": "docker compose down -v && docker compose up -d",
    "services:logs": "docker compose logs -f",
    "prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d",
    "prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down",
    "prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.production logs -f",
    "prod:setup": "node scripts/setup-production.mjs",
    "prod:backup": "docker compose -f docker-compose.prod.yml --env-file .env.production run --rm postgres-backup sh -lc 'pg_dump -h 127.0.0.1 -p ${POSTGRES_PORT:-5432} -U ${POSTGRES_USER:-cfitv} -d ${POSTGRES_DB:-cfitv} -Fc > /backups/manual-$(date +%Y%m%d-%H%M%S).dump'"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.59.1"
  }
}
