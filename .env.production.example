# ============================================================
# Circuit Fit TV — exemple production locale gym
# ------------------------------------------------------------
# Copier vers .env.production et remplacer les secrets/IP.
# Ne pas versionner .env.production.
# ============================================================

# Adresse LAN stable du serveur Proxmox/LXC/mini-PC.
SERVER_LAN_IP=192.168.1.10

# ----- Backend -----
NODE_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
LOG_LEVEL=info
MDNS_ENABLED=true

# Générer une valeur unique de 32+ caractères :
# openssl rand -base64 48
JWT_SECRET=replace_with_a_unique_very_long_random_secret_32_chars_min
# Durée de session coach/admin. Raccourcir en environnement moins fiable.
JWT_EXPIRES_IN=8h

# Optionnel : bootstrap admin au premier démarrage.
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-me-now

# ----- PostgreSQL -----
POSTGRES_USER=cfitv
POSTGRES_PASSWORD=replace_with_a_strong_database_password
POSTGRES_DB=cfitv
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cfitv:replace_with_a_strong_database_password@127.0.0.1:5432/cfitv?schema=public

# ----- MinIO -----
MINIO_ROOT_USER=cfitv_admin
MINIO_ROOT_PASSWORD=replace_with_a_strong_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://192.168.1.10:9000
S3_ACCESS_KEY=cfitv_admin
S3_SECRET_KEY=replace_with_a_strong_minio_password
S3_BUCKET_VIDEOS=videos
S3_BUCKET_THUMBNAILS=thumbnails

# ----- Redis -----
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# ----- Backups -----
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
