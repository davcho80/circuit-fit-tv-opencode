{
  "name": "@cfitv/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Serveur Fastify + WebSocket pour Circuit Fit TV",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=../.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.{ts,json,md}'",
    "test": "tsx src/sessions/orchestrator.test.ts && tsx src/routes/circuits.schema.test.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:migrate:prod": "prisma migrate deploy --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:generate": "prisma generate --config prisma.config.ts",
    "create-admin": "tsx --env-file=../.env src/scripts/create-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@cfitv/shared": "*",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bonjour-service": "^1.3.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.15.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
