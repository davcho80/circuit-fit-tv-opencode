// ============================================================
// Circuit Fit TV — Prisma Schema
// ------------------------------------------------------------
// Source de vérité DB. Doit rester cohérent avec les modèles
// Zod dans packages/shared/src/models.ts.
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----- Enums -----

enum UserRole {
  ADMIN
  COACH
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum RotationMode {
  CLASSIC
  FIXED
}

enum DisplayRole {
  STATION
  CENTRAL
  UNASSIGNED
}

enum SessionStatus {
  RUNNING
  PAUSED
  COMPLETED
  ABORTED
}

enum PhaseType {
  TRANSITION
  WORK
  REST
  HYDRATION
}

// ----- Exercise -----

model Exercise {
  id           String     @id @default(uuid())
  name         String     @db.VarChar(100)
  description  String?    @db.VarChar(280)
  videoUrl     String
  thumbnailUrl String
  durationSec  Int
  muscleGroups String[]   @default([])
  equipment    String[]   @default([])
  difficulty   Difficulty
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Stations qui référencent cet exercice
  stationExercises CircuitStationExercise[]
}

// ----- Circuit -----

model Circuit {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(100)
  description    String?      @db.VarChar(500)
  rounds         Int
  workSec        Int
  restSec        Int
  transitionSec  Int
  rotationMode   RotationMode
  icon           String?      @db.VarChar(10)   // emoji ou court identifiant
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  stations        CircuitStation[]
  sessions        Session[]
  scheduledBreaks ScheduledBreak[]
  schedules       Schedule[]
}

model Schedule {
  id          String    @id @default(uuid())
  circuit     Circuit   @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  circuitId   String
  name        String    @db.VarChar(100)
  daysOfWeek  Int[]                     // ISO 1=Lundi … 7=Dimanche
  timeHour    Int                       // 0–23
  timeMinute  Int                       // 0–59
  timezone    String    @default("America/Montreal")
  startDate   DateTime  @db.Date        // première semaine active
  endDate     DateTime? @db.Date        // dernière semaine active (null = indéfini)
  isActive    Boolean   @default(true)
  lastFiredAt DateTime?                 // horodatage du dernier déclenchement
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
}

model ScheduledBreak {
  id          String  @id @default(uuid())
  circuit     Circuit @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  circuitId   String
  afterRound  Int     // break se déclenche après avoir complété ce round (1-based)
  durationSec Int     // durée de la pause en secondes
  label       String  @default("Pause eau")

  @@index([circuitId])
}

model CircuitStation {
  id        String  @id @default(uuid())
  circuit   Circuit @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  circuitId String
  position  Int
  layoutX   Float?
  layoutY   Float?

  exercises CircuitStationExercise[]

  @@unique([circuitId, position])
}

// Table de jointure Station ↔ Exercise (ordre possible dans le futur)
model CircuitStationExercise {
  station    CircuitStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  stationId  String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  exerciseId String

  @@id([stationId, exerciseId])
}

// ----- Display -----

model Display {
  id            String      @id @default(uuid())
  name          String      @db.VarChar(50)
  role          DisplayRole @default(UNASSIGNED)
  stationNumber Int?
  lastSeen      DateTime?
  deviceModel   String?
  deviceOs      String?
  appVersion    String?
  pairedAt      DateTime?
}

// ----- Session -----

model Session {
  id                 String        @id @default(uuid())
  circuit            Circuit       @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  circuitId          String
  startedAt          DateTime      @default(now())
  endedAt            DateTime?
  status             SessionStatus @default(RUNNING)
  currentRound       Int           @default(1)
  currentPhase       PhaseType     @default(TRANSITION)
  currentStationIdx  Int           @default(0)
  phaseEndsAt        DateTime?
  pausedAt           DateTime?
  remainingOnPauseMs Int?
}

// ----- Studio Settings (singleton) -----

model StudioSettings {
  id           String  @id @default("singleton")
  studioName   String  @default("Circuit Fit TV") @db.VarChar(100)
  primaryColor String  @default("#0ea5e9") @db.VarChar(7)
  logoUrl      String?
  timezone     String  @default("America/Montreal") @db.VarChar(60)
}

// ----- User -----

model User {
  id                 String    @id @default(uuid())
  email              String    @unique @db.VarChar(255)
  passwordHash       String
  role               UserRole  @default(COACH)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([email])
}
